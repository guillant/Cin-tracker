# Copiez ce fichier vers .env. Il n'est jamais exposé au navigateur.
# Option A : modèle OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Option B : modèle local Ollama (OPENAI_API_KEY peut rester vide)
# OPENAI_API_URL=http://127.0.0.1:11434/v1/chat/completions
# OPENAI_MODEL=qwen3:8b
# AI_REQUEST_TIMEOUT_MS=300000

RAPIDAPI_KEY=
TMDB_API_KEY=
PORT=4173
# Comma-separated origins allowed to call the API (add the production PWA URL).
ALLOWED_ORIGINS=http://localhost,capacitor://localhost
